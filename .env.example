# CineForge AI Pro — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# ── IBM watsonx.ai ─────────────────────────────────────────────────────────
WATSONX_API_KEY=""
WATSONX_PROJECT_ID=""
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite model used for scene reasoning / cinematic prompt generation.
# This MUST be set to a Granite model ID that is verified as available in
# your specific watsonx.ai environment and project. Do not invent model IDs.
# Confirm available models via the watsonx.ai console or API before setting.
GRANITE_MODEL_ID=""

# ── Application Security ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_32_byte_hex_string
ENCRYPTION_SALT=replace_with_random_32_byte_hex_string

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend (Next.js — prefix NEXT_PUBLIC_ for client-side access) ─────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CineForge AI Pro
