# CineForge AI Pro — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# ── IBM watsonx.ai ─────────────────────────────────────────────────────────
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Application Security ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_32_byte_hex_string
ENCRYPTION_SALT=replace_with_random_32_byte_hex_string

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend (Next.js — prefix NEXT_PUBLIC_ for client-side access) ─────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CineForge AI Pro
